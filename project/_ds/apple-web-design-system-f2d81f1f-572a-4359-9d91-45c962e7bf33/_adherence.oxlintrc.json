{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/forms/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/soomin-web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|type|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, type, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|dark|pearl|store-hero)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'dark' | 'pearl' | 'store-hero'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfiguratorChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:thumb|label|delta|selected|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<ConfiguratorChip> doesn't accept that prop. Declared props: thumb, label, delta, selected, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|links|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: heading, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|eyebrow|title|tagline|primaryCta|secondaryCta|onPrimary|onSecondary|children|style|key|ref|className|style|children)$/]",
        "message": "<ProductTile> doesn't accept that prop. Declared props: variant, eyebrow, title, tagline, primaryCta, secondaryCta, onPrimary, onSecondary, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductTile'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|parchment|dark|dark-2|dark-3)$/]",
        "message": "<ProductTile> variant must be one of 'light' | 'parchment' | 'dark' | 'dark-2' | 'dark-3'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, onChange, placeholder, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoreCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|name|price|action|onAction|accent|style|key|ref|className|style|children)$/]",
        "message": "<StoreCard> doesn't accept that prop. Declared props: image, name, price, action, onAction, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SubNavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<SubNavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|onDark|chevron|style|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: children, href, onDark, chevron, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
